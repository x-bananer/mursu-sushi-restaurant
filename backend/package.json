{
  "name": "backend",
  "version": "1.0.0",
  "description": "A scalable Node.js backend for a modern sushi restaurant application",
  "private": true,
  "main": "src/server.js",
  "scripts": {
    "dev": "nodemon src/server.js",
    "db:setup": "node src/models/db/schemas/setup.db.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "fix": "eslint . --fix && prettier . --write",
    "docs:api": "apidoc -i src/controllers -o docs/api",
    "test:integration": "NODE_ENV=test node --experimental-vm-modules ./node_modules/jest/bin/jest.js --config jest.config.js --runInBand --detectOpenHandles",
    "test:user-flow": "node tests/user.test.js",
    "test:combo-flow": "node tests/combo.test.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "@mapbox/polyline": "^1.2.1",
    "argon2": "^0.44.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.1",
    "multer": "^2.0.2",
    "mysql2": "^3.22.0",
    "stripe": "^22.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "apidoc": "^1.2.0",
    "eslint": "^9.39.4",
    "globals": "^17.4.0",
    "jest": "^30.3.0",
    "nodemon": "^3.1.14",
    "prettier": "^3.6.2",
    "supertest": "^7.2.2"
  }
}
