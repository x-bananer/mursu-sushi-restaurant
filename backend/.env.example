# ── SERVER ─────────────────────────────
PORT=3000

# ── DATABASE ───────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=sushi_restaurant
SUSHI_RESTAURANT_DB_USER=mursu_user
SUSHI_RESTAURANT_DB_PASSWORD=mursu_password

DB_ADMIN_USER=root
DB_ADMIN_PASSWORD=your_root_password

# ── STRIPE ─────────────────────────────
STRIPE_SECRET_KEY=sk_test_your_key_here

# ── RESTAURANT COORDS ────────────────
RESTAURANT_LAT=60.1719
RESTAURANT_LON=24.9410

# ── ROUTING INTEGRATION ────────────────
HSL_API_KEY=ask_for_key
ORS_API_KEY=ask_for_key
# Get a free key at:
#https://openrouteservice.org/dev/#/signup
# Free tier: 2000 requests/day, 40/minute
HSL_BASE_URL =https://api.digitransit.fi/routing/v2/hsl/gtfs/v1
ORS_BASE_URL =https://api.openrouteservice.org/v2/directions/driving-car

# ── AUTH ───────────────────────────────
JWT_SECRET=your_string_secret
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your_refresh_secret
ADMIN_SECRET=your_admin_secret
